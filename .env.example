# ════════════════════════════════════════════════════════════════════════════
# NWS Alert Dashboard — configuration
#
# Quick start: set LOCATION and one notification target (NTFY_* or
# NOTIFY_URLS), then `docker compose up -d --build`. Everything else has
# sensible defaults. Variables are grouped by alert source (RADIO_*, NWWS_*,
# API_*) plus cross-source groups (FILTER_*, NOTIFY_*, MQTT_*, MAP_*, SITE_*).
# ════════════════════════════════════════════════════════════════════════════

# ── Location auto-setup (recommended) ────────────────────────────────────────
# "lat,lon" of your home. Derives FILTER_SAME_CODES, API_ZONES, FILTER_ZONES,
# and a radio frequency scan list for any of those left blank. Explicit
# values below always win.
LOCATION=

# ── Cross-source filters ─────────────────────────────────────────────────────
# Space-separated PSSCCC SAME area codes (6-digit: P + state FIPS + county
# FIPS). Applied to every source. Blank = derived from LOCATION.
# Lookup: https://www.weather.gov/nwr/counties
FILTER_SAME_CODES=

# UGC forecast zones for zone-based products (winter storms, special weather
# statements). Blank = derived from LOCATION.
FILTER_ZONES=

# Seconds within which two arrivals of the same event+county are considered
# the same alert (cross-source dedup window)
DEDUP_WINDOW_SECS=600

# ── Radio source (RTL-SDR + NOAA Weather Radio) ──────────────────────────────
# Works fully offline: decoded alert + broadcast recording + county map even
# when the internet is down. Set false if you have no SDR dongle.
RADIO_ENABLED=true

# Record broadcast audio for routine test messages (RWT/RMT/NPT/NST/NAT/DMO)?
# Radio always decodes every event; tests still ingest (and are hidden in the
# UI by default), but their audio isn't worth keeping. Leave false to skip the
# WAV for every weekly/monthly test; set true if you want test recordings.
RADIO_RECORD_TESTS=false

# RTL-SDR USB device path on the host (find with: lsusb | grep -i rtl),
# used by compose.override.yaml
RTL_DEVICE=/dev/bus/usb/001/002

# NWR frequency in MHz (US channels: 162.400–162.550). Blank = scan list
# derived from LOCATION; the silence rotation below finds the active channel.
RADIO_FREQUENCY=
RADIO_FREQUENCY_FALLBACK=

# Rotate to the next frequency after this many hours without a decode;
# return to primary after FAILBACK hours on a fallback
RADIO_SILENCE_TIMEOUT_HOURS=24
RADIO_FAILBACK_HOURS=72

# RTL-SDR tuning. GAIN: 0=auto, 40, 49.6 (max for most dongles).
# PPM: run rtl_test -p to calibrate, 0 if unknown. SQUELCH: keep 0 —
# squelch can swallow SAME bursts and cause missed decodes.
RADIO_GAIN=49.6
RADIO_PPM=0
RADIO_BANDWIDTH=48k
RADIO_SQUELCH=0

# Audio capture window: seconds to wait for the voice message + EOM before
# saving the broadcast recording
RADIO_VOICE_WAIT=180
RADIO_HEADER_LEAD_SECS=7
RADIO_EOM_TRAIL_SECS=3

# ── NWWS-OI source (NWS Weather Wire Service, XMPP push) ─────────────────────
# Fastest delivery path. Free NWS-issued credentials required (can take 30+
# days): https://www.weather.gov/nwws/
NWWS_ENABLED=false
NWWS_USER=
NWWS_PASS=
NWWS_SERVERS=nwws-oi-cprk.weather.gov nwws-oi-bldr.weather.gov
NWWS_ROOM=nwws@conference.nwws-oi.weather.gov
NWWS_RESOURCE=nwws
# Product PIL prefixes to consider (3-letter AWIPS id prefixes)
NWWS_PILS=TOR SVR SVS FFW FFS FLW FLS FFA EWW SMW MWS SQW WSW NPW WCN WOU SEL SPS CEM CDW LAE EVI SPW HLS CFW
# Restrict to issuing offices (cccc codes, e.g. KDTX). Blank = all
# (the UGC/county filter still applies either way)
NWWS_OFFICES=
# true = parse and log matches without ingesting/notifying (first-day soak)
NWWS_LOG_ONLY=false

# ── NOAA REST API source (api.weather.gov polling) ───────────────────────────
# Always-on safety net; also enriches radio-decoded alerts with the full
# text and storm polygon. No signup needed.
API_ENABLED=true
# Zones to poll: county UGC (XXC###) and/or forecast zone (XXZ###),
# space-separated. Blank = derived from LOCATION.
API_ZONES=
# Poll interval; the degraded interval is used while NWWS-OI is down/disabled
API_POLL_SECS=120
API_POLL_SECS_DEGRADED=30
API_BASE_URL=https://api.weather.gov
# api.weather.gov requires a contact in the User-Agent — put your email here
API_USER_AGENT=nws-alert-dashboard (you@example.com)

# ── Notifications ────────────────────────────────────────────────────────────
# Apprise URLs, space-separated — Discord, Telegram, Pushover, email, and
# ~80 more services: https://github.com/caronc/apprise#supported-notifications
# Example: NOTIFY_URLS=discord://webhook_id/webhook_token
NOTIFY_URLS=

# ntfy shortcut (adds an ntfy target with per-alert priority + topic routing).
# Leave NTFY_URL blank if you only use NOTIFY_URLS.
NTFY_URL=
NTFY_USER=
NTFY_PASS=

# NOTIFICATION gate: space-separated event codes that may notify (Apprise + web
# push + MQTT). This is the master allowlist; the NOTIFY_PRIORITY_* lists below
# only assign priority/topic to events that pass this gate — they do NOT filter,
# so anything here but unlisted below still notifies at NTFY_PRIORITY_DEFAULT.
# Alerts for codes NOT listed here are still ingested and shown on the dashboard
# (this never affects the UI) — they just don't ping you. Blank = notify on all.
# Includes standard SAME/EAS codes plus internal pseudo-codes for common non-EAS
# advisories that only arrive via API/NWWS (EHW Excessive Heat, HTY Heat
# Advisory, WWY Winter Weather Advisory, RFW Red Flag) — trim if unwanted.
# Routine broadcast tests (RWT/RMT/NPT/NST/NAT/DMO) are intentionally absent so
# they never notify; they still ingest and are hidden in the UI by default. Add
# them back if you want test notifications (e.g. to confirm the pipeline).
# Also the upper bound for web push: the dashboard's per-device notification
# picker only offers codes listed here; a device can narrow but never widen it.
NOTIFY_EVENT_CODES=ADR AVA AVW BHW BWW BZW CAE CDW CEM CFA CFW CHW CWW DBA DBW DEW DSW EAN EAT EQW EVA EVI EWW FCW FFA FFS FLA FLS FFW FLW FRW FSW FZW HLS HMW HUA HUW HWA HWW IBW IFW LAE LEW LSW NIC NMN NUW POS RHW SMW SPW SPS SQW SSA SSW SVA SVR SVS TOA TOE TOR TRA TRW TSA TSW VOW WFA WFW WSA WSW EHW EHA HTY ECW ECA WCW WCY WCA WWY WIY FGY FRY FZA HZW HZA RFW FWA DUY AQA SMY DUW CFY CFS LFW LFA LFY LFS HYY BZA ISW LKW LKA LKY ZRY ZFY CWY XHW XHA TSY SUW SUY RPS BHS ASY AFW AFY LWY BSY BLU GLW GLA SRW SRA HFW HFA SEW SEA SCY SIY RBY SWY BWY UPY UPW UPA LOY MFY MWS TYW TYA TYS

# Event-code → notification priority routing. List event codes in exactly
# one group; checked highest-first. Unlisted codes use the defaults below.
NOTIFY_PRIORITY_5_CODES=TOR EVI FFW EAN NUW
NTFY_PRIORITY_5_TOPIC=nws
NOTIFY_PRIORITY_4_CODES=BZW EQW EVA EWW FRW SPW SVR TOA WSW HWW LEW RHW FLW CEM LAE CHW HMW BHW EHW ECW WCW RFW HZW ISW LKW XHW HFW GLW SRW SEW SUW AFW UPW TYW BLU
NTFY_PRIORITY_4_TOPIC=nws
NOTIFY_PRIORITY_3_CODES=ADR BWW CDW CWW DBA DBW DEW FCW FSW FZW IFW LSW NIC POS SPS SSW SVA SVS TOE TRA WFA WSA SQW EHA HTY ECA WCY WCA WWY WIY FGY FRY FZA HZA FWA DUY AQA SMY DUW CFY CFS LFW LFA LFY LFS HYY BZA LKA LKY ZRY ZFY CWY XHA TSY SUY RPS BHS ASY AFY LWY BSY GLA SRA HFA SEA SCY SIY RBY SWY BWY UPY UPA LOY MFY MWS TYA TYS
NTFY_PRIORITY_3_TOPIC=nws
NTFY_TOPIC_DEFAULT=nws
NTFY_PRIORITY_DEFAULT=3

# Attach the alert polygon map PNG to notifications (ntfy needs
# attachment-cache-dir configured server-side; falls back to text-only).
# FOLLOWUP sends one low-priority map message if the polygon arrives after
# the initial notification (typical for radio-first alerts).
NOTIFY_MAP_ATTACH=true
NOTIFY_MAP_FOLLOWUP=true

# Re-notify when NWS revises an already-notified alert in place (reworded text,
# tightened polygon, raised severity). Modes:
#   off        — never re-notify (dashboard still updates + shows the badge)
#   escalation — only when severity rises or the text adds "Tornado Emergency" /
#                "Particularly Dangerous Situation"   (default)
#   all        — any content revision
RENOTIFY_ON_UPDATE=escalation
# Minimum seconds between re-notifications for the same alert (anti-fatigue)
RENOTIFY_MIN_INTERVAL_SECS=600
# How many prior versions to keep for the card's "Revision history"
REVISION_HISTORY_MAX=12

# ── MQTT (Home Assistant integration) ────────────────────────────────────────
# Publishes alert JSON to {MQTT_TOPIC}/alert and a retained active-alert
# summary to {MQTT_TOPIC}/active on every notification and update.
MQTT_ENABLED=false
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=nws-alerts

# ── Maps ─────────────────────────────────────────────────────────────────────
# A one-time startup job caches county/zone boundaries and a small OSM tile
# pyramid (~10-15 MB) for your area, so alert maps render fully offline.
MAP_ENABLED=true
# Counties to cache map data for (defaults to FILTER_SAME_CODES)
MAP_SAME_CODES=
# Buffer around home counties; storm polygons routinely extend a county out
MAP_BUFFER_KM=120
MAP_ZOOM_MIN=6
MAP_ZOOM_MAX=11
# Tile source. Keep the cache small per the OSM tile usage policy, or point
# at e.g. CartoDB dark: https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}.png
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_CACHE_DIR=/alerts/mapdata
MAP_REFRESH_DAYS=30
MAP_WIDTH=900
MAP_HEIGHT=600

# ── Radar overlay (dashboard maps only) ──────────────────────────────────────
# Animated, time-correct NEXRAD radar on the per-alert dashboard maps for
# precip/convective events (tornado, thunderstorm, flood, winter, tropical).
# Online enrichment: the browser fetches archived radar tiles from Iowa State's
# mesonet (which re-serves NWS NEXRAD) — it never touches the offline notification
# PNGs. The loop spans the event (onset→now while active, then replays
# onset→expiry) and a pin marks your LOCATION on every map. Set false to disable.
RADAR_ENABLED=true
# Tile template; {stamp} is a UTC YYYYMMDDHHMM 5-min frame slot.
RADAR_TILE_URL=https://mesonet.agron.iastate.edu/cache/tile.py/1.0.0/ridge::USCOMP-N0Q-{stamp}/{z}/{x}/{y}.png
RADAR_STEP_MIN=5          # minutes between frames (NEXRAD composites are 5-min)
RADAR_LOOKBACK_MIN=20     # always reach back this far so a just-issued alert animates
RADAR_MAX_FRAMES=24       # cap; longer events coarsen the step to fit
RADAR_MAX_SPAN_HOURS=2    # finished events trim to this trailing window (active alerts always span their full life)
RADAR_OPACITY=0.55        # radar layer opacity; lower lets county/road basemap show through
RADAR_FRAME_MS=450        # playback ms per frame
RADAR_DWELL_MS=1400       # extra pause on the newest frame each loop
RADAR_LATENCY_SEC=300     # trail "now" by this much (radar publish lag)

# ── Web UI ───────────────────────────────────────────────────────────────────
SITE_TITLE=NWS Alert Dashboard
# Header subtitle. Blank = auto: the detected location from LOCATION
# (nearest city + forecast office), or the raw lat,lon if lookup is unavailable.
SITE_SUBTITLE=
SITE_FOOTER=
# Show the in-browser notification (web-push) controls in the dashboard.
# Set false to hide them entirely (e.g. behind a proxy without HTTPS).
WEB_PUSH_ENABLED=true
# Contact for browser web-push (VAPID) claims
PUSH_VAPID_EMAIL=you@example.com
# waitress worker threads. Each open dashboard tab holds one thread for its
# SSE alert stream (plus one more while playing the live audio), so size this
# above your expected concurrent viewers. Default fits a handful of tabs.
WEB_THREADS=24
# Serve under a reverse-proxy sub-path (e.g. https://host/radio/) by honoring
# the X-Forwarded-Prefix header so every emitted URL is prefixed. Leave unset
# for a normal root deployment. Enable ONLY behind a proxy that sets
# X-Forwarded-Prefix authoritatively AND strips any client-supplied one —
# otherwise the prefix can be spoofed. Never set on a directly-exposed port.
# TRUST_PROXY=1

# ── Retention & monitoring ───────────────────────────────────────────────────
# Days to keep alert audio recordings + map images (0 = forever)
AUDIO_RETAIN_DAYS=365
# Days to keep alert DB records (0 = forever)
DB_RETAIN_DAYS=0
# Uptime Kuma push URL for health monitoring (blank = disabled)
UPTIME_PUSH_URL=
